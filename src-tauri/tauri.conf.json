{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sythoria",
  "version": "0.3.0",
  "identifier": "com.sythoria.sythoria-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Sythoria",
        "width": 1400,
        "height": 900,
        "transparent": false,
        "decorations": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 30
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data: https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
