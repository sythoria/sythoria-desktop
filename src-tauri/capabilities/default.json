{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "core:event:allow-listen",
      "allow": [
        { "event": "chat-stream-chunk" },
        { "event": "chat-stream-done" },
        { "event": "ws-error" },
        { "event": "ws-closed" },
        { "event": "ws-message" }
      ]
    },
    "opener:default",
    "store:default",
    "log:default",
    "autostart:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-start-dragging"
  ]
}
